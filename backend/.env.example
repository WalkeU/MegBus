# Ezt a fájlt másold .env néven, és töltsd ki valós értékekkel a szerveren.
# A .env sose kerül git-be (lásd .gitignore) — csak ez a példa-sablon van commitolva.

# A backend Node-folyamat portja a konténeren belül (ne módosítsd, ha a
# docker-compose.yml-t változatlanul használod).
PORT=3000

# Production: állítsd a valódi domainedre (pl. https://megbus.example.com),
# hogy csak onnan fogadjon kéréseket a szerver. Fejlesztéshez a '*' megfelelő.
CORS_ORIGIN=*

# A domain, amire a Caddy Let's Encrypt TLS-tanúsítványt kér, és amit a
# reverse proxy kiszolgál (lásd Caddyfile). DNS A-rekordként a szerver
# IP-jére kell mutatnia, mielőtt elindítod a konténereket.
DOMAIN=megbus.example.com

# Ezeket a kód jelenleg még nem használja ténylegesen (nincs élő DB/Redis-kapcsolat
# bekötve) — a jövőbeli Prisma/Redis integrációhoz vannak előkészítve.
DATABASE_URL=postgresql://user:password@localhost:5432/megbus
REDIS_URL=redis://localhost:6379
